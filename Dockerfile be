FROM node:20-alpine

WORKDIR /app

COPY roho_backend_repo/package*.json ./roho_backend_repo/

WORKDIR /app/roho_backend_repo

RUN npm install

COPY roho_backend_repo/ .

RUN npm run build

RUN npm install -g pm2

EXPOSE 8081

CMD ["pm2-runtime", "start", "npm", "--name", "roho-be-core", "--", "start"]
